# ============================================================
# Copie este arquivo para .env.local e preencha com os valores
# reais. O .env.local NUNCA deve ser commitado (já está no
# .gitignore). Nenhuma dessas variáveis chega ao navegador —
# elas só existem no servidor (rota /api/unlock).
# ============================================================

# A senha romântica que ela precisa digitar no cofre.
# A comparação ignora maiúsculas/minúsculas, acentos e espaços
# nas pontas (ex.: "Te Amo" == "te amo" == "tê amo").
# Se a senha for uma DATA, qualquer formato com os mesmos dígitos
# vale: "19/03/2022" == "19032022" == "19 de março de 2022".
UNLOCK_PASSWORD=senha_romantica_aqui

# Dados do gift card da Shein (só são enviados após a senha correta)
SHEIN_GIFT_CARD_NUMBER=0000-0000-0000-0000
SHEIN_GIFT_CARD_PIN=000000
